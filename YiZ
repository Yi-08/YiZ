<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YiZ</title>
    <link href="https://fonts.googleapis.com/css2?family=Emblema+One&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-blue: #AFCFFE;
            --primary-pink: #FFCAE2;
            --accent-blue: #0047AB;
            --dark-text: #333;
        }

        body { 
            font-family: 'Segoe UI', Arial, sans-serif; 
            margin: 0; 
            padding: 0;
            background-color: var(--primary-pink); 
            color: var(--dark-text); 
        }

        /* --- 导航栏核心修改 --- */
        header {
            background-color: var(--primary-blue);
            color: white;
            padding: 15px 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 100;
            /* 使用 Grid 确保中间 Logo 绝对居中 */
            display: grid;
            grid-template-columns: 1fr auto 1fr; 
            align-items: center;
        }

        /* 登录区域（左侧） */
        .user-login-area {
            justify-self: start;
            position: relative;
        }

        /* Logo 区域（中间） */
        .logo-area {
            text-align: center;
        }

        .logo-area h1 { 
            font-size: 2.5rem; 
            margin: 0; 
            font-family: 'Emblema One', cursive; 
            letter-spacing: 2px;
            line-height: 1.2;
        }
        .slogan { margin: 0; font-size: 0.85rem; opacity: 0.9; }

        /* 购物车区域（右侧） */
        .user-cart-area {
            justify-self: end;
        }

        /* 登录浮窗位置修正 */
        .login-box {
            display: none; 
            position: absolute; 
            top: 45px; 
            left: 0; /* 靠左对齐 */
            background: white; 
            padding: 20px; 
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15); 
            width: 220px;
            z-index: 1001;
        }
        .login-box input { 
            width: 100%; 
            padding: 8px; 
            margin-bottom: 10px; 
            border: 1px solid #ddd;
            border-radius: 5px;
            box-sizing: border-box; 
        }

        /* --- 通用样式 --- */
        .container { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
        
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
            gap: 30px; 
        }

        .card { 
            background: white; 
            border-radius: 20px; 
            overflow: hidden; 
            box-shadow: 0 10px 20px rgba(0,0,0,0.05); 
            transition: all 0.3s ease;
            border: 1px solid #eee;
        }

        /* 悬停动画：轻微上浮 */
        .card:hover { 
            transform: translateY(-10px); 
            box-shadow: 0 15px 30px rgba(175, 207, 254, 0.4); 
        }

        .card img { 
    width: 100%; 
    height: auto;       /* 让高度根据图片比例自动撑开 */
    display: block;     /* 消除图片底部微小的间隙 */
    object-fit: contain; /* 确保内容不被裁剪 */
}
        .card-info { padding: 20px; text-align: center; }
        .price { color: var(--accent-blue); font-weight: bold; font-size: 1.2rem; }

        .btn { 
            background: var(--accent-blue); 
            color: white; 
            border: none; 
            padding: 10px 20px; 
            border-radius: 10px; 
            cursor: pointer; 
            font-weight: 600;
            transition: 0.3s;
        }
        .btn:hover { transform: scale(1.05); background: #003580; }

        /* 侧边购物车 */
        .drawer {
            position: fixed; right: -450px; top: 0; width: 400px; height: 100%;
            background: white; box-shadow: -10px 0 30px rgba(0,0,0,0.1);
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); z-index: 1000; 
            display: flex; flex-direction: column;
            color: var(--dark-text);
        }
        .drawer.open { right: 0; }
        .drawer-header { padding: 20px; background: #f8f8f8; display: flex; justify-content: space-between; align-items: center; }
        .drawer-body { flex: 1; overflow-y: auto; padding: 20px; }
        .cart-footer { padding: 20px; border-top: 2px solid var(--primary-pink); }
    </style>
</head>
<body>

<header>
    <div class="user-login-area">
        <div id="loginSection">
            <span id="welcomeText" style="margin-right:10px;">你好，访客</span>
            <button class="btn" style="padding: 5px 12px;" onclick="toggleLogin()">账户</button>
            <div id="loginBox" class="login-box">
                <input type="text" id="uName" placeholder="用户名">
                <input type="password" id="uPass" placeholder="密码">
                <button class="btn" style="width:100%" onclick="handleLogin()">登录</button>
                <button class="btn" style="width:100%; background:#888; margin-top:5px;" onclick="handleLogout()">登出</button>
            </div>
        </div>
    </div>

    <div class="logo-area">
        <h1>YiZ</h1>
        <p class="slogan">在律动中找到属于自己的生命节奏</p>
    </div>

    <div class="user-cart-area">
        <button class="btn" onclick="toggleCart()">🛒 购物车 (<span id="countDisplay">0</span>)</button>
    </div>
</header>

<div class="container">
    <h2>运动装备系列</h2>
    <div class="grid" id="mainGrid"></div>
</div>

<div id="cartDrawer" class="drawer">
    <div class="drawer-header">
        <h3>我的清单</h3>
        <button class="btn" style="background:none; color:#333; font-size:1.5rem;" onclick="toggleCart()">×</button>
    </div>
    <div class="drawer-body" id="cartContent"></div>
    <div class="cart-footer">
        <div style="margin-bottom: 15px;">
            <input type="text" id="promoInput" placeholder="折扣码: YIZ10" style="width:60%; padding:8px;">
            <button class="btn" style="padding:8px;" onclick="applyPromo()">应用</button>
        </div>
        <div style="display:flex; justify-content:space-between; font-weight:bold; font-size:1.2rem; margin-bottom:15px;">
            <span>应付总额:</span>
            <span>RM <span id="finalTotal">0</span></span>
        </div>
        <button class="btn" style="width:100%; padding:15px;" onclick="doCheckout()">立即结算支付</button>
    </div>
</div>

<script>
    const storeProducts = [
        { 
            id: 1, 
            shop: "YiZ", 
            name: "运动衣", 
            price: 30, 
            stock: 12, 
            img: "shirt1.jpg" // 确保这里只有文件名，没有 images/
        },
        { 
            id: 2,
            shop: "YiZ", 
            name: "球拍", 
            price: 100, 
            stock: 5, 
            img: "paddle1.jpg" 
        },
        { 
            id: 3, 
            shop: "YiZ", 
            name: "球(桶)", 
            price: 10, 
            stock: 30, 
            img: "ball.jpg" 
        }
    ];

    let myCart = JSON.parse(localStorage.getItem('YiZ_Storage_Cart')) || [];
    let loggedUser = localStorage.getItem('YiZ_Logged_User') || "";
    let promoDiscount = 0;

    function init() {
        renderProducts();
        refreshCartUI();
        if(loggedUser) {
            document.getElementById('welcomeText').innerText = "你好, " + loggedUser;
        }
    }

    function renderProducts() {
        const grid = document.getElementById('mainGrid');
        if (!grid) return;
        grid.innerHTML = storeProducts.map(p => `
            <div class="card">
                <img src="${p.img}" alt="${p.name}" onerror="this.src='https://via.placeholder.com/280x220?text=图片待上传'">
                <div class="card-info">
                    <p style="font-size:0.8rem; color:#888;">${p.shop}</p>
                    <h3>${p.name}</h3>
                    <p class="price">RM ${p.price}</p>
                    <button class="btn" onclick="addToCart(${p.id})">加入购物车</button>
                </div>
            </div>
        `).join('');
    }

    function refreshCartUI() {
        const cartContent = document.getElementById('cartContent');
        const finalTotalDisplay = document.getElementById('finalTotal');
        const countDisplay = document.getElementById('countDisplay');
        
        let bill = 0;
        let html = myCart.map((item, idx) => {
            bill += (item.price * item.qty);
            return `
                <div style="display:flex; align-items:center; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px;">
                    <img src="${item.img}" style="width:50px; height:50px; border-radius:5px;" onerror="this.src='https://via.placeholder.com/50x50?text=图'">
                    <div style="flex:1; margin-left:10px;">
                        <div style="font-size:0.9rem;">${item.name}</div>
                        <div style="font-weight:bold; color:var(--accent-blue);">RM ${item.price}</div>
                    </div>
                    <div>
                        <button onclick="updateQty(${idx}, -1)">-</button>
                        <span style="margin:0 5px;">${item.qty}</span>
                        <button onclick="updateQty(${idx}, 1)">+</button>
                    </div>
                </div>`;
        }).join('');

        cartContent.innerHTML = html || "购物车是空的";
        finalTotalDisplay.innerText = Math.max(0, bill - promoDiscount);
        countDisplay.innerText = myCart.reduce((sum, i) => sum + i.qty, 0);
        localStorage.setItem('YiZ_Storage_Cart', JSON.stringify(myCart));
    }

    function addToCart(prodId) {
        const product = storeProducts.find(item => item.id === prodId);
        const cartItem = myCart.find(item => item.id === prodId);
        if (cartItem) cartItem.qty++;
        else myCart.push({ ...product, qty: 1 });
        refreshCartUI();
        document.getElementById('cartDrawer').classList.add('open');
    }

    function updateQty(index, change) {
        myCart[index].qty += change;
        if (myCart[index].qty <= 0) myCart.splice(index, 1);
        refreshCartUI();
    }

    function toggleCart() { document.getElementById('cartDrawer').classList.toggle('open'); }
    
    function toggleLogin() { 
        const box = document.getElementById('loginBox');
        box.style.display = box.style.display === 'block' ? 'none' : 'block';
    }

    function handleLogin() {
        const user = document.getElementById('uName').value;
        if(user) {
            loggedUser = user;
            localStorage.setItem('YiZ_Logged_User', user);
            document.getElementById('welcomeText').innerText = "你好, " + user;
            toggleLogin();
        }
    }

    function handleLogout() {
        localStorage.removeItem('YiZ_Logged_User');
        location.reload();
    }

    function applyPromo() {
        if(document.getElementById('promoInput').value === "YIZ10") {
            promoDiscount = 10;
            alert("已减 RM10");
            refreshCartUI();
        } else {
            alert("无效的折扣码");
        }
    }

    function doCheckout() {
        if(!loggedUser) return alert("请先登录账户再结算");
        if(myCart.length === 0) return alert("购物车还是空的哦");
        alert("支付成功！感谢支持 YiZ Sports。");
        myCart = [];
        refreshCartUI();
    }

    // 统一在这里初始化
    window.onload = init;
</script>
</body>
</html>
